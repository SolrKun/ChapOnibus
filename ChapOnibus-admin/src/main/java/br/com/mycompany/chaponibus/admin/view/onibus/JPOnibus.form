              <AuxValues>
                <AuxValue name="JavaCodeGenerator_InitCodePost" type="java.lang.String" value="// Alinha o redimensionamento autom&#xe1;tico&#xa;jTOnibus.setAutoResizeMode(javax.swing.JTable.AUTO_RESIZE_ALL_COLUMNS);&#xa;&#xa;// Coluna 1 (Papel) ter&#xe1; um tamanho fixo e controlado&#xa;jTOnibus.getColumnModel().getColumn(1).setPreferredWidth(150);&#xa;&#xa;// Coluna 0 (Usuario) vai engolir todo o resto do espa&#xe7;o da tabela automaticamente&#xa;jTOnibus.getColumnModel().getColumn(0).setPreferredWidth(300);&#xa;&#xa;// Impede o usu&#xe1;rio de arrastar e reordenar as colunas de lugar (ex: puxar &quot;Papel&quot; para antes de &quot;Usuario&quot;)&#xa;jTOnibus.getTableHeader().setReorderingAllowed(false);&#xa;&#xa;// Impede o usu&#xe1;rio de mudar a largura das colunas arrastando com o mouse&#xa;jTOnibus.getTableHeader().setResizingAllowed(false);"/>
              </AuxValues>
            </Component>
